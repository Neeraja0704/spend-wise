# Environment variables (currently not used, for future extensibility)
# This file can be used for:
# - API endpoints
# - Authentication tokens
# - Feature flags
# - Configuration values

# Example (uncomment and configure as needed):
# REACT_APP_API_URL=http://localhost:3000/api
# REACT_APP_AUTH_TOKEN=your_token_here
# REACT_APP_ENABLE_DARK_MODE=false
# REACT_APP_MAX_UPLOAD_SIZE=5242880
